{
  "name": "update.electronjs.org",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/bin/update-server.js",
    "start-test-server": "cross-env NODE_ENV=test node dist/bin/test-update-server.js",
    "lint": "oxfmt --check . && oxlint",
    "lint:fix": "oxfmt --write . && oxlint --fix",
    "typecheck": "tsc --noEmit",
    "test": "npm run lint && npm run typecheck && cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest watch",
    "test:ui": "cross-env NODE_ENV=test vitest --ui",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "dotenv-safe": "^9.1.0",
    "ms": "^2.1.3",
    "pino": "^8.12.1",
    "redis": "^5.8.3",
    "redlock": "^4.2.0",
    "request-ip": "^3.3.0",
    "semver": "^7.5.2"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/dotenv-safe": "^9.1.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.6.2",
    "@types/redlock": "^4.0.7",
    "@types/request-ip": "^0.0.41",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "nock": "^14.0.11",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "fsevents": "npm:@electron/fsevents@2.3.3-fork"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "*.json": [
      "oxfmt --write"
    ]
  },
  "packageManager": "yarn@4.10.3+sha512.c38cafb5c7bb273f3926d04e55e1d8c9dfa7d9c3ea1f36a4868fa028b9e5f72298f0b7f401ad5eb921749eb012eb1c3bb74bf7503df3ee43fd600d14a018266f"
}
